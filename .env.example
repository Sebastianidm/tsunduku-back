# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tsundoku_db
SPRING_DATASOURCE_USERNAME=tsundoku_user
SPRING_DATASOURCE_PASSWORD=tsundoku_password

# Redis Configuration
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# JWT Security (Must be at least 256 bits / 32 bytes for HS256)
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long_tsundoku_backend_2026
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
